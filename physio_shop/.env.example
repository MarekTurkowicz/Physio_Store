# ──────────────────────────────────────────────────────────────
# PhysioStore — Environment Variables
# Copy to .env and fill in your values before running.
# ──────────────────────────────────────────────────────────────

# Application
APP_NAME=PhysioShop
APP_VERSION=1.0.0
DEBUG=false

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/physioshop

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_TTL=300

# ── JWT ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Celery ─────────────────────────────────────────────────────
# Leave empty to use REDIS_URL automatically
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Email / SMTP ───────────────────────────────────────────────
# Dev default: MailHog at http://localhost:8025
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@physiostore.pl
SMTP_TLS=false

# Production (Gmail example):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# SMTP_TLS=true

# ── Business rules ─────────────────────────────────────────────
LOW_STOCK_THRESHOLD=5
MANAGER_REPORT_EMAIL=manager@physiostore.pl

# ── Rate limiting ──────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_SECONDS=900
